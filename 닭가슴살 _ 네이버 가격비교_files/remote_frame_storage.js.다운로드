/**
 * window.localStorage 객체의 래퍼 클래스이다.
 * localStorage 객체의 getItem(), setItem() 메서드외에 추가 메서드를 제공한다.
 * @class nhn.mobile.fs.Storage
 * @extends nhn.mobile.fs.Component
 * @keyword 로컬스토리지, 스토리지, storage
 * @history Update 2.0.0 라이브러리(JindoJS) 의존도 없앰
 * @history Update 2.0.0 이벤트 이름에서 앞 'on' 문자열 제거
 */
nhn.mobile.fs.Storage = nhn.mobile.fs.Component.extend({
  //--------------------------------------------------------------------------
  //
  //	Constructor
  //
  //--------------------------------------------------------------------------

  /**
   * 인스턴스를 생성한다.
   * @constructor
   * @remark - 생성후 ready() 메서드를 호출하고, 'ready' 이벤트 핸들러에서 이후 동작을 하는 것을 권장한다.
   * @example
   *      new nhn.mobile.fs.Storage();
   */
  construct : function(){
    this._initVar();
  },

  //--------------------------------------------------------------------------
  //
  //	Methods
  //
  //--------------------------------------------------------------------------

  //----------------------------------
  //	of public
  //----------------------------------

  /**
   * 스토리지 기능을 사용할 수 있도록 준비한다.
   * @method ready
   * @remark - 'ready' 이벤트가 발생한다.
   * @remark - 생성시엔 커스텀 이벤트 핸들러가 호출되지 않기 때문에 인스턴스 생성후, 핸들러를 부착하고 나서 본 메서드를 필히 호출하도록 한다.
   * @return {this}
   * @example
   *      var oS = new nhn.mobile.fs.Storage();
   *      oS.on("ready", function(oEvent){
	 *          // start application
	 *      }).ready();
   */
  ready : function(){
    /**
     * 스토리지 기능을 사용할 수 있는 상태가 되었을 때.
     * @event ready
     * @param {Boolean} bIsSupport 로컬 스토리지를 사용할 수 있는지 여부. true : 사용할 수 있음, false : 사용할 수 없음
     * @remark - 본 이벤트는 최초 한번만 발생한다.
     */
    !this.isReady() && this.fire("ready", {bIsSupport : this.isSupport()});
    this._bIsReady = true;

    return this;
  },

  /**
   * 스토리지 기능을 사용할 준비가 되었는지 여부를 반환한다.
   * @method isReady
   * @returns {Boolean} true : 준비 완료, false : 아직 준비 안됨
   */
  isReady : function(){
    return !!this._bIsReady;
  },

  /**
   * window.localStorage 객체를 사용할 수 있는지 여부를 반환한다.
   * @method isSupport
   * @returns {Boolean} true : 로컬 스토리지를 사용할 수 있다, false : 로컬 스토리지를 사용할 수 없다.
   * @remark - 쿠키를 비허용하거나 프라이빗 브라우징 모드를 사용하는 등 여러 이유에 의해 사용불가 일 수 있다.
   */
  isSupport : function(){
    return this._isSupportsLocalStorage();
  },

  /**
   * localStorage 에 데이터를 저장한다. 저장 후, 'onAddItem' 이벤트가 발생된다.
   * @method setItem
   * @param {String} sKey key 로 사용되어질 문자열 값.
   * @param {String} oValue value 로 사용되어질 값.
   * @example
   *      new nhn.mobile.fs.Storage().setItem("age", "24");
   */
  setItem : function(sKey, oValue){
    try{
      this._oLocalStorage.setItem(sKey, oValue);

      /**
       setItem() 메서드를 호출하면 발생된다.

       @event addItem
       @param {String} itemKey setItem() 메서드 호출시 지정한 key 값.
       **/
      this.fire("addItem", {itemKey : sKey});
    }catch(e){
      console.log(e);
    }
  },

  /**
   * localStorage 에 여러 데이터를 저장한다.
   * @method setItmes
   * @param {Object} htItem key 와 value 쌍으로 이루어진 객체. 객체의 속성을 key 로, 속성의 값을 value 로 사용한다.
   * @example
   *      new nhn.mobile.fs.Storage().setItems({
	 *          age : 24,
	 *          name : "john",
	 *          tall : 180,
	 *          weight : 70
	 *      });
   */
  setItems : function(htItem){
    var sKey;

    try{
      for(sKey in htItem){
        this._oLocalStorage.setItem(sKey, htItem[sKey]);
      }
    }catch(e){
      console.log(e);
    }
  },

  /**
   * localStorage 에 저장된 데이터를 반환한다. 반환 후, 'onReadItem' 이벤트가 발생된다.
   * @method getItem
   * @param {String} sKey 반환받을 value 를 참조할 key.
   * @return {String} sKey 에 해당하는 key 의 value 값.
   * @example
   *      var oStorage = new nhn.mobile.fs.Storage();
   *      oStorage.setItem("age", "24");
   *      oStorage.getItem("age"); // "24"
   */
  getItem : function(sKey){
    var sValue;

    try{
      sValue = this._oLocalStorage.getItem(sKey);

      /**
       * getItem() 메서드를 호출하면 발생된다.
       * @event readItem
       * @param {String} itemKey getItem() 메서드 호출시 지정한 key 값.
       * @param {String} itemValue itemKey 에 대한 저장된 value 값.
       */
      this.fire("readItem", {itemValue : sValue, itemKey : sKey});
    }catch(e){
      console.log(e);
    }

    return sValue;
  },

  /**
   * localStorage 에 저장된 데이터를 모두 반환한다. 'onReadAllItem' 이벤트가 발생된다.
   * @method getAllItems
   * @return {Object} 저장된 모든 데이터를 key 와 value 쌍으로 이루어 놓은 객체
   * @example
   *      var oStorage = new nhn.mobile.fs.Storage();
   *      oStorage.setItems({
	 *          age : 24,
	 *          name : "john",
	 *          tall : 180,
	 *          weight : 70
	 *      });
   *      oStorage.getAllItems(); // {age : "24", name : "john", tall : "180", weight : "70"}
   */
  getAllItems : function(){
    var nLength = 0,
        oItems = {},
        sKey,
        i;

    try{
      nLength = this._oLocalStorage.length;

      for(i = 0; i < nLength; i++){
        sKey = this._oLocalStorage.key(i);
        oItems[sKey] = this._oLocalStorage.getItem(sKey);
      }

      /**
       * getAllItems() 메서드를 호출하면 발생된다.
       * @event readAllItem
       * @param {Object} item 저장된 모든 데이터를 key 와 value 쌍으로 이루어 놓은 객체
       **/
      this.fire("readAllItem", {item : oItems});
    }catch(e){
      console.log(e);
    }

    return oItems;
  },

  /**
   * localStorage 에 저장된 데이터를 삭제한다.
   * @method removeItem
   * @param {String} sKey 삭제 할 데이터의 key.
   * @example
   *      new nhn.mobile.fs.Storage().removeItem("age");
   */
  removeItem : function(sKey){
    try{
      this._oLocalStorage.removeItem(sKey);

      /**
       * removeItem() 메서드를 호출하면 발생된다.
       * @event removeItem
       * @param {Object} itemKey removeItem() 메서드 호출시 지정한 key 값.
       */
      this.fire("removeItem", {itemKey : sKey});
    }catch(e){
      console.log(e);
    }
  },

  /**
   * localStorage 에 저장된 데이터를 모두 삭제한다.
   * @method clearStorage
   * @example
   *      new nhn.mobile.fs.Storage().clearStorage();
   */
  clearStorage : function(){
    try{
      this._oLocalStorage.clear();

      /**
       * clearStorage() 메서드를 호출하면 발생된다.
       * @event clearStorage
       */
      this.fire("clearStorage");
    }catch(e){
      console.log(e);
    }
  },

  /**
   * localStorage 에 저장된 데이터의 개수를 반환한다.
   * @method getLength
   * @return {Number} 데이터의 총 개수
   * @example
   *      var oStorage = new nhn.mobile.fs.Storage();
   *      oStorage.setItems({
	 *          age : 24,
	 *          name : "john",
	 *          tall : 180,
	 *          weight : 70
	 *      });
   *      oStorage.getLength(); // 4
   */
  getLength : function(){
    var nLength = 0;

    try{
      nLength = this._oLocalStorage.length;
    }catch(e){
      console.log(e);
    }

    return nLength;
  },

  /**
   * localStorage 를 사용 할수 있는지의 여부 체크
   * @method _isSupportsLocalStorage
   * @return {Boolean} 사용가능 여부.
   * @private
   **/
  _isSupportsLocalStorage : function(){
    var b = false;

    try{
      b = "localStorage" in window && window.localStorage !== null;
    }catch(e){
      console.log(e);
    }

    return b;
  },

  /**
   * window 객체의 localStorage 속성을 비공개 멤버변수에 지정한다.
   * @method reloadStorage
   * @example
   *      new nhn.mobile.fs.Storage().reloadStorage();
   */
  reloadStorage : function(){
    try{
      this._oLocalStorage = window.localStorage;
    }catch(e){
      console.log(e);
    }
  },

  /**
   * window 객체의 localStorage 속성을 참조하고 있는 멤버변수에 null 을 지정한다.
   * @method destroy
   * @example
   *      new nhn.mobile.fs.Storage().destroy();
   */
  destroy : function() {
    this._oLocalStorage = null;
  },

  //----------------------------------
  //	of private
  //----------------------------------

  /**
   * 인스턴스 변수를 초기화한다.
   * @method _initVar
   * @private
   */
  _initVar : function(){
    try{
      this._oLocalStorage = window.localStorage;
    }catch(e){
      console.log(e);
    }
  }
});

/**
 * @author sshyun 현성식(AjaxUI2), chohwihun
 * @version 2.0.0
 * @since 2011. 8. 10.
 **/
/**
 * 외부 도메인에서 현재 도메인의 localStorage 에 데이터의 get/set 요청이 오면 요청한 곳으로 회신해주는 클래스이다.
 * @class nhn.mobile.fs.RemoteFrameStorage
 * @extends nhn.mobile.fs.Storage
 * @uses nhn.mobile.fs.FrameMessageReceiver
 * @keyword 리모트프레임스토리지, 프레임스토리지, remote, frame, storage
 * @remark - 외부 도메인에서 보내온 메시지는 window 객체의 <b>'message' 이벤트</b>를 통해 받고, 회신할 때는 외부 도메인 자원의 <b>contentWindow.postMessage()</b> 메서드를 이용하여 회신한다.
 * @remark - nhn.mobile.fs.LocalFrameStorage 와 데이터를 주고 받는 예제는 <a href="./nhn.mobile.fs.LocalFrameStorage.html#demo">nhn.mobile.fs.LocalFrameStorage 데모</a>를 참조하면 된다.
 */
nhn.mobile.fs.RemoteFrameStorage = nhn.mobile.fs.Storage.extend({
  //--------------------------------------------------------------------------
  //
  //	Constructor
  //
  //--------------------------------------------------------------------------

  /**
   * 인스턴스를 생성한다.
   * @constructor
   * @param {Object} htParam 생성자 파라미터 객체.
   * @param {Boolean} [htParam.bCheckDomain=false] 도메인 체크 여부. true : 체크함, false : 체크안함
   * @param {Array} [htParam.aWhiteDomainList=[]] 허용 도메인 리스트
   * @example
   *      // 옵션 없이 생성하는 예
   *      new nhn.mobile.fs.RemoteFrameStorage();
   *
   *      // 옵션을 지정하여 생성하는 예
   *      new nhn.mobile.fs.RemoteFrameStorage({
	 *          bCheckDomain  : true,
	 *          aWhiteDomainList : ["test1.com", "test2.com"]
	 *      });
   */
  construct : function(htParam){
    this.option(htParam || {});
  },

  //--------------------------------------------------------------------------
  //
  //    Override Methods
  //
  //--------------------------------------------------------------------------

  /**
   * 스토리지 기능을 사용할 수 있도록 준비한다.
   * @method ready
   * @remark - 'ready' 이벤트가 발생한다.
   * @remark - 생성시엔 커스텀 이벤트 핸들러가 호출되지 않기 때문에 인스턴스 생성후, 핸들러를 부착하고 나서 본 메서드를 필히 호출하도록 한다.
   * @remark - nhn.mobile.fs.FrameMessageReceiver 인스턴스의 <a href="./nhn.mobile.fs.FrameMessageReceiver.html#method_start">start()</a> 메서드를 호출하여 window 객체의 'message' 이벤트 핸들링을 시작한다.
   * @return {this}
   * @example
   *      var oRFS = new nhn.mobile.fs.RemoteFrameStorage().on("ready", function(oEvent){
	 *          // start application
	 *      }).ready();
   */
  ready : function(){
    if(!this.isReady()){
      this._oReceiver.start(this.callback("_onResponseStorageData"));
      this.fire("ready", {bIsSupport : this._isSupportsLocalStorage()});
    }

    this._bIsReady = true;

    return this;
  },

  //--------------------------------------------------------------------------
  //
  //	Methods
  //
  //--------------------------------------------------------------------------

  /**
   * 부모의 <a href="./nhn.mobile.fs.Storage.html#method_destroy">destroy()</a> 메서드를 호출한다. nhn.mobile.fs.FrameMessageReceiver 인스턴스의 <a href="./nhn.mobile.fs.FrameMessageReceiver.html#method_destroy">destroy()</a> 메서드를 호출한다.
   * @method  destroy
   * @override
   * @example
   *      new nhn.mobile.fs.RemoteFrameStorage().destroy();
   */
  destroy : function(){
    this._oReceiver.destroy();
  },

  //----------------------------------
  //	of public
  //----------------------------------

  /**
   * 인스턴스 변수를 초기화한다.
   * @method _initVar
   * @private
   */
  _initVar : function(){
    nhn.mobile.fs.Storage.prototype._initVar.call(this);
    this._oReceiver = new nhn.mobile.fs.FrameMessageReceiver(this.option());
  },

  //----------------------------------
  //	of private
  //----------------------------------

  /**
   * sActionType 에 매칭되는 동작을 수행한다.
   * @method _excuteAction
   * @param {String} sActionType 액션 종류.
   * @param {Object} oData Param 데이터.
   * @return {Object} 회신으로 보낼 데이터.
   * @private
   */
  _excuteAction : function(sActionType, oData){
    var oResultData = {};

    try{
      // 종류별 액션에 따라 기능 수행.
      switch(sActionType){
        case "GET_ITEM" :
          oResultData["value"] = this.getItem(oData.key);
          oResultData["key"] = oData.key;

          break;
        case "SET_ITEM" :
          this.setItem(oData.key, oData.value);
          oResultData["key"] = oData.key;

          break;
        case "REMOVE_ITEM" :
          this.removeItem(oData.key);
          oResultData["key"] = oData.key;

          break;
        case "CLEAR_STORAGE" :
          this.clearStorage();

          break;
        default:
          break;
      }
      oResultData["success"] = true;
    }catch(e){
      oResultData["success"] = false;
    }
    return oResultData;
  },

  /**
   * window 객체의 'message' 이벤트의 핸들러. 원격지에서 보내온 데이터를 받아 가공하여 회신용 객체를 생성하여 반환한다.
   * @method _onResponseStorageData
   * @param {Object} oReqData 수신받은 액션 데이터.
   * @private
   */
  _onResponseStorageData : function(oReqData){
    var oData = oReqData.reqData,
        // 액션 동작 구분.
        sActionType = (oData.action) ? oData.action : "none";

    // 회신 데이터.
    return {
      reqId : oReqData.reqId,
      resData : this._excuteAction(sActionType, oData)
    };
  }
});

(typeof nhn === "undefined") && (nhn = {});
nhn.mobile = nhn.mobile || {};
nhn.mobile.fs = nhn.mobile.fs || {};

/**
 * 프레임 스토리지 클래스들이 정의되어 있는 네임스페이스
 * @class nhn.mobile.fs
 * @remark - 네임스페이스 이지만 API 참조 문서의 클래스 리스트에 나타내기 위해 편의상 Class 로 나타나게 함
 */
/**
 * 클래스를 생성하여 반환한다.
 * @method createClass
 * @static
 * @param {Object} oDef 메서드 이름이 key, 메서드 함수가 value 로 이루어져 있는 해시 테이블.
 * @remark - 생성자를 정의 하려면 oDef 에 'construct' key 로 함수를 정의해야 한다.
 * @remark - 생성된 클래스에는 그 클래스를 상속받을 수 있는 extend() static 메서드가 정의되어 있다.
 * @return {Object} oDef 에 정의된 함수를 메서드로 갖는 클래스.
 * @example
 *      var Man = nhn.mobile.fs.createClass({
 *          construct : function(nAge){
 *              this._nAge = nAge;
 *          },
 *          getAge : function(){
 *              return "Man age : " + this._nAge;
 *          }
 *      });
 *      new Man(20).getAge(); // 20
 *      console.log(typeof Man.extend); // "function"
 */
nhn.mobile.fs.createClass = function(oDef){
  var Class = function Class(){

    if(oDef.construct instanceof Function){
      oDef.construct.apply(this, arguments);
    }
  };

  Class.prototype = oDef;
  Class.prototype.constructor = Class;
  Class.extend = nhn.mobile.fs.extend;

  return Class;
};

/**
 * nhn.mobile.fs.createClass() 메서드를 통해 생성된 클래스의 static 메서드이다. 클래스를 상속받는 하위 클래스를 생성하여 반환한다.
 * @method extend
 * @static
 * @param {Object} oDef 메서드 이름이 key, 메서드 함수가 value 로 이루어져 있는 해시 테이블.
 * @returns {Object} 부모 클래스를 상속받은 클래스.
 * @example
 *      var Man = nhn.mobile.fs.createClass({
 *          construct : function(nAge){
 *              this._nAge = nAge;
 *          },
 *          getAge : function(){
 *              return "Man age : " + this._nAge;
 *          }
 *      });
 *      var YoungMan = Man.extend({
 *          construct : function(nAge){
 *              this._nAge = nAge;
 *          },
 *          // 메서드 오버라이딩
 *          getAge : function(){
 *              // 부모 메서드는 부모 클래스의 prototype 에 접근하여 호출해야 한다.
 *              return Man.prototype.getAge.call(this) + ", YoungMan age : " + this._nAge;
 *          }
 *      });
 *      var oYM = new YoungMan(10);
 *      oYM.getAge(); // "Man age : 10, YoungMan age : 10"
 */
nhn.mobile.fs.extend = function(oDef){
  var SuperClass = this,
      Class = function Class(){
        SuperClass.apply(this, arguments);

        if(oDef.construct instanceof Function){
          oDef.construct.apply(this, arguments);
        }
      },
      ExtProto,
      oExtProto,
      sKey;

  ExtProto = function(){};
  ExtProto.prototype = SuperClass.prototype;
  oExtProto = new ExtProto();

  for(sKey in oDef){
    if(oDef.hasOwnProperty(sKey)){
      oExtProto[sKey] = oDef[sKey];
    }
  }

  Class.prototype = oExtProto;
  Class.prototype.constructor = Class;
  Class.extend = arguments.callee;
  //Class.$super = SuperClass.prototype; //'super' is supported not yet.

  return Class;
};

/**
 * 프레임 스토리지 클래스들의 기본 클래스.
 * @class nhn.mobile.fs.Component
 * @remark 1. 생성자 파라미터를 객체로 지정하여 option() 메서드를 통해 get/set 할 수 있음
 * @remark 2. 사용자 정의 이벤트를 발송하고 그 이벤트의 핸들러를 탈부착 함
 * @remark 3. 함수 바인딩 기능 제공
 * @remark 4. 안드로이드/ios 여부와 두 os의 버전 문자열 반환 함
 */
nhn.mobile.fs.Component = nhn.mobile.fs.createClass({
  /**
   * 인스턴스를 생성한다.
   * @constructor
   * @param {Object} [htParam={}] 생성자 파라미터 객체
   */
  construct : function(htParam){
    this._htHandler = {};
    this._htOption = {};
    this.option(htParam || {});
  },

  /**
   * 옵션 값을 반환한다.
   * @method option
   * @param {String} sName 옵션의 이름
   * @return {Variant} 옵션의 값
   */
  /**
   * 옵션 값을 지정한다.
   * @method option
   * @syntax sName, vValue
   * @syntax oValue
   * @param {String} sName 옵션 이름
   * @param {Variant} vValue 옵션 값.
   * @param {Object} oValue 하나 이상의 이름과 값을 가지는 옵션 객체
   * @return {this} 현재 인스턴스
   * @remark sName 파라미터에 undefined 를 지정하면 sName 에 undefined 가 지정되진 않고, 단지 sName 옵션 값이 반환된다.
   * @example
   *      var oComp = new nhn.mobile.ac.Component();
   *      oComp.option("foo", 123);
   *      oComp.option("foo"); // 123
   */
  option : function(sName, vValue){
    var ht,
        i;

    switch(typeof sName){
      case "undefined" :
        ht = {};

        for(i in this._htOption){
          ht[i] = this._htOption[i];
        }

        return ht;

      case "string" :
        if(typeof vValue === "undefined"){
          return this._htOption[sName];
        }else{
          this._htOption[sName] = vValue;
        }

        break;

      case "object" :
        for(i in sName){
          this._htOption[i] = sName[i];
        }

        break;
    }

    return this;
  },

  /**
   * 이벤트를 발생시킨다.
   * @method fire
   * @param {String} sEvent 이벤트 이름.
   * @param {Object} [oEvent={}] 이벤트 핸들러 함수의 첫번째 파라미터로 지정되는 객체. 기본적으로 sType(이벤트 이름) 속성이 정의되어 있다.
   * @return {Boolean} 이벤트 핸들러에서 oEvent 파라미터의 stop() 메서드를 호출하면 false 가, 호출하지 않으면 true 가 반환된다.
   * @example
   *      // html
   *      <button onclick="oComp.say();">Click me</button>
   *
   *      // javascript
   *      var MyComponent = nhn.mobile.ac.Class({
	 *          say : function(){
	 *              this.fire("say", {
	 *                  sText : "blar blar"
	 *              });
	 *          }
	 *      }).extend(nhn.mobile.ac.Component);
   *
   *      var oComp = new MyComponent().on({
	 *          say : function(oEvent){
	 *              alert(oEvent.sText); // "blar blar"
	 *          }
	 *      });
   */
  fire : function(sEvent, oEvent){
    oEvent = oEvent || {};

    var aHandlerList = this._htHandler[sEvent] || [],
        bHasHandlerList = aHandlerList.length > 0,
        aArg,
        i,
        nLen,
        fHandler;

    if(!bHasHandlerList){
      return true;
    }

    aHandlerList = aHandlerList.concat(); // fire수행시 핸들러 내부에서 off되어도 최초수행시의 핸들러리스트는 모두 수행
    oEvent.sType = sEvent;

    if(typeof oEvent._aExtend === "undefined"){
      oEvent._aExtend = [];
      oEvent.stop = function(){
        if(oEvent._aExtend.length > 0){
          oEvent._aExtend[oEvent._aExtend.length - 1].bCanceled = true;
        }
      };
    }

    oEvent._aExtend.push({
      sType : sEvent,
      bCanceled : false
    });

    aArg = [oEvent];
    nLen = arguments.length;

    for(i = 2; i < nLen; i++){
      aArg.push(arguments[i]);
    }

    for(i = 0; (fHandler = aHandlerList[i]); i++){
      fHandler.apply(this, aArg);
    }

    return !oEvent._aExtend.pop().bCanceled;
  },

  /**
   * 이벤트 핸들러를 등록한다.
   * @method on
   * @syntax sEvent, fHandler
   * @syntax htEvent
   * @param {String} sEvent 이벤트 이름
   * @param {Function} fHandler sEvent 이벤트 발생시 수행할 핸들러 함수
   * @param {Object} fHandler.oEvent fHandler 함수에 파라미터로 지정될 이벤트 객체, 기본적을 sType 속성을 참조할 수 있으며, 속성을 추가하고 싶으면 fire() 메서드의 두번째 파라미터에 정의하면 된다.
   * @param {String} fHandler.oEvent.sType 이벤트 이름.
   * @param {Object} htEvent key 는 이벤트 이름, value 는 핸들러 함수로 이루어진 해시 테이블
   * @return {this} 컴포넌트 인스턴스 자신
   * @example
   *      var fSayHandler = function(oEvent){};
   *      var fSayHandler2 = function(oEvent){};
   *      var fRunHandler = function(oEvent){};
   *      var oComp = new nhn.mobile.ac.Component();
   *
   *      // 이벤트 이름과 핸들러 함수를 파라미터로 지정하는 예.
   *      oComp.on("say", fSayHandler);
   *
   *      // key 에는 이벤트 이름, value 에는 핸들러 함수를 지정한 해시 테이블을 파라미터로 지정하는 예.
   *      oComp.on({
	 *          say : fSayHandler2,
	 *          run : fRunHandler
	 *      });
   */
  on : function(sEvent, fHandler){
    var i,
        aHandler = this._htHandler[sEvent];

    if(arguments.length === 1){
      for(i in arguments[0]){
        this.on(i, arguments[0][i]);
      }

      return this;
    }

    !aHandler && (aHandler = this._htHandler[sEvent] = []);
    aHandler.push(fHandler);

    return this;
  },

  /**
   * 이벤트 핸들러를 탈착한다.
   * @method off
   * @syntax sEvent, fHandler
   * @syntax htEvent
   * @param {String} sEvent 이벤트 이름
   * @param {Function} fHandler 등록 탈착 할 sEvent 이벤트의 핸들러 함수
   * @param {Object} htEvent key 는 이벤트 이름, value 는 핸들러 함수로 이루어진 해시 테이블
   * @return {this} 컴포넌트 인스턴스 자신
   * @example
   *      var fSayHandler = function(oEvent){};
   *      var fSayHandler2 = function(oEvent){};
   *      var fRunHandler = function(oEvent){};
   *      var oComp = new nhn.mobile.ac.Component();
   *
   *      // 이벤트 이름과 핸들러 함수를 파라미터로 지정하는 예.
   *      oComp.off("say", fSayHandler);
   *
   *      // key 에는 이벤트 이름, value 에는 핸들러 함수를 지정한 해시 테이블을 파라미터로 지정하는 예.
   *      oComp.off({
	 *          say : fSayHandler2,
	 *          run : fRunHandler
	 *      });
   */
  off : function(sEvent, fHandler){
    var i,
        fHandler,
        aHandler = this._htHandler[sEvent];

    if(arguments.length === 1){
      for(i in arguments[0]){
        this.off(i, arguments[0][i]);
      }

      return this;
    }

    if(aHandler){
      for(i = 0; (fHandler = aHandler[i]); i++){
        if(fHandler === fHandler){
          aHandler = aHandler.splice(i, 1);

          break;
        }
      }
    }

    return this;
  },

  /**
   * 등록된 모든 커스텀 이벤트 핸들러를 탈착한다.
   * @method offAll
   * @param {String} sEvent 이벤트명. 생략시 모든 등록된 커스텀 이벤트 핸들러를 탈착한다.
   * @return {this} 컴포넌트 인스턴스 자신
   * @example
   *      var fSayHandler = function(oEvent){};
   *      var fSayHandler2 = function(oEvent){};
   *      var fRunHandler = function(oEvent){};
   *      var oComp = new nhn.mobile.ac.Component();
   *
   *      oComp.off("say", fSayHandler);
   *      oComp.off({
	 *          say : fSayHandler2,
	 *          run : fRunHandler
	 *      });
   *
   *      // "say" 이벤트에 부착된 모든 핸들러 함수를 탈착함.
   *      oComp.offAll("say");
   *
   *      // 부착된 모든 이벤트 핸들러 함수를 탈착함.
   *      oInst.offAll();
   */
  offAll : function(sEvent){
    var ht = this._htHandler,
        i;

    if(arguments.length){

      if(typeof ht[sEvent] === "undefined"){
        return this;
      }

      delete ht[sEvent];

      return this;
    }

    for(i in ht){
      delete ht[i];
    }

    return this;
  },

  /**
   * f 파라미터에 지정한 함수의 this context 를 현재 인스턴스로 변경한 함수를 반환한다.
   * @method callback
   * @param {Function|String} f this context 를 변경할 함수. 현재 인스턴스의 메서드인 경우 메서드 이름을 지정해도 된다.
   * @param {Object} [oScope=this] context 로 지정하고 하는 객체
   * @param {Array} [aBeforeArgs] 반환될 함수에 지정될 파라미터중 앞쪽에 추가할 파라미터
   * @param {Array} [aAfterArgs] 반환될 함수에 지정될 파라미터중 뒤쪽에 추가할 파라미터
   * @returns {Function}
   * @example
   *
   */
  callback : function(f, oScope, aBeforeArgs, aAfterArgs){
    (typeof f === "string") && (f = this[f]);
    oScope = oScope || this;

    return function(){
      var args = arguments.length ? Array.prototype.slice.call(arguments) : [];

      aBeforeArgs && (args = aBeforeArgs.concat(args));
      aAfterArgs && (args = args.concat(aAfterArgs));

      return f.apply(oScope, args);
    }
  }
});

/**
 * @author sshyun 현성식(AjaxUI2), chohwihun
 * @version 2.0.0
 * @since 2011. 8. 10.
 */
/**
 * window 객체의 'message' 이벤트가 발생되면 이 이벤트를 발생시킨 곳으로 콜백 함수를 실행한 결과를 postMessage() 메서드를 호출하여 보낸다.
 * @class nhn.mobile.fs.FrameMessageReceiver
 * @extends nhn.mobile.fs.Component
 * @keyword 프레임메시지리시버, 프레임, 메시지리시버, frame, message, receiver
 * @remark - 인스턴스 생성자에 bCheckDomain : true 를 지정하고, aWhiteDomain 에 허용 도메인 리스트가 존재할 때, 이 리스트에 없는 도메인에서 메시지가 오면 회신을 하지 않는다.
 */
nhn.mobile.fs.FrameMessageReceiver = nhn.mobile.fs.Component.extend({
  //--------------------------------------------------------------------------
  //
  //	Constructor
  //
  //--------------------------------------------------------------------------

  /**
   * 인스턴스를 생성한다.
   * @constructor
   * @param {Object} htParam 사용자 정의 옵션. 생략하려면 빈 객체를 지정해야 함.
   * @param {Boolean} [htParam.bCheckDomain=false] 도메인 체크 여부. true : 체크함, false : 체크안함
   * @param {Array} [htParam.aWhiteDomainList=[]] 허용 도메인 리스트
   * @remark window 객체의 postMessage() 메서드가 없다면 인스턴스가 생성되지 않는다.
   * @example
   *      // 옵션 없이 생성
   *      new nhn.mobile.fs.FrameMessageReceiver();
   *
   *      // 옵션을 지정하여 생성
   *      new nhn.mobile.fs.FrameMessageReceiver({
	 *          bCheckDomain  : true,
	 *          aWhiteDomainList : ["test1.com", "test2.com"]
	 *      });
   */
  construct : function(htParam){
    if(!window.postMessage){
      throw new Error("Unsupported browser.");
    }

    this.option({
      bCheckDomain : false,
      aWhiteDomainList :[]
    });
    this.option(htParam || {});
    this._assignValueToMemberVariable();
    this._attachEventListener();
  },

  //--------------------------------------------------------------------------
  //
  //	Methods
  //
  //--------------------------------------------------------------------------

  //----------------------------------
  //	of public
  //----------------------------------

  /**
   * 메시지 수신을 시작한다. 현재 자원(html)에서 window 객체의 'message' 이벤트가 발생하면 fCallback 함수를 호출하고, 그 함수에서 반환해준 값을 원격지 자원으로 보낸다.<br/>
   * @method start
   * @param {Function} fCallback 현재 자원의 window 객체에 'message' 이벤트 발생시 '원격지 자원으로 보낼 데이터'를 반환해주는 함수. 반환하는 객체에 reqId, resData 속성을 필수로 정의해야 한다.
   *      @param {Object} fCallback.htData fCallback 함수에 전달되는 파라미터. FrameMessageSender 객체에서 보낸 원본 그대로의 데이터.
   *      @param {Window} fCallback.htData.host 원격지의 window 객체.
   *      @param {Object} fCallback.htData.hostDomain 원격지의 origin(프로토콜 + 도메인) 문자열. ex. 'https://m.search.naver.com'
   *      @param {String} fCallback.htData.reqId FrameMessageSender 에서 지정한, 현재 처리하고 있는 'message' 이벤트의 id
   *      @param {Object} fCallback.htData.reqData FrameMessageSender 에서 지정한, 현재 처리하고 있는 'message' 이벤트의 data
   *      @param {Object} fCallback.return fCallback 함수의 반환 값.
   *          @param {String} fCallback.return.reqId htData 파라미터의 reqId 속성 값을 그대로 지정해야 한다.
   *          @param {Object} fCallback.return.resData 원격지 자원으로 보낼 응답 데이터
   * @return {this} 현재 인스턴스
   * @example
   *      new nhn.mobile.fs.FrameMessageReceiver().start(function(htData){
	 *          console.log(htData.reqId);
	 *          console.log(htData.reqData);
	 *          console.log(htData.host);
	 *          console.log(htData.hostDomain);
	 *
	 *          return{
	 *              reqId : htData.reqId,
	 *              resData : {
	 *                  // 회신할 데이터
	 *              }
	 *          };
	 *      });
   */
  start : function(fCallback){
    this._fCallback = fCallback;

    return this;
  },

  /**
   * 내부 멤버변수에 null 을 지정한다.
   * @method destroy
   * @example
   *      new nhn.mobile.fs.FrameMessageReceiver().destroy();
   */
  destroy : function(){
    window.removeEventListener("message", this._fOnMessage);
    this._aWhiteServerDomains = null;
    this._fOnMessage = null;
  },

  //----------------------------------
  //	of private
  //----------------------------------

  /**
   * 인스턴스 변수를 초기화한다.
   * @method _initVar
   * @param {Object} htOption 옵션 정보.
   * @private
   */
  _assignValueToMemberVariable : function(htOption){
    this._fOnMessage = this.callback("_onMessage");
    this._bCheckDomain = this.option("bCheckDomain");
    this._aWhiteServerDomains = this.option("aWhiteDomainList");
  },

  /**
   * 이벤트를 바인드한다.
   * @method _attachEvent
   * @private
   */
  _attachEventListener : function(){
    window.addEventListener("message", this._fOnMessage);
  },

  /**
   * sDomain 이 허용리스트에 있는지 검증한다.
   * @method _isVerifyDomain
   * @param {String} sDomain 검사할 도메인 문자열
   * @return {Boolean} 허용 도메인 여부.
   * @private
   */
  _isVerifyDomain : function(sDomain){
    var aWhiteDomains = this._aWhiteServerDomains,
        nLength = aWhiteDomains.length,
        bCheck = false,
        i;

    sDomain = sDomain.replace(/^https?:\/\/|:\d{1,4}$/g, "").toLowerCase();

    if(sDomain === "naver.com" || /\.naver\.com$/.test(sDomain)){
      return true;
    }

    for(i = 0; i < nLength; i++){

      if(aWhiteDomains[i] === sDomain){
        bCheck = true;

        break;
      }
    }

    return bCheck;
  },

  /**
   * window 객체에 'message' 이벤트를 발생시키게 한 원격지로 회신 메시지를 보낸다. htData 가 없거나, htData.reqId, htData.resData 가 없다면 Error 가 발생된다.
   * @method _sendMessage
   * @param {Window} oRequestHost 원격지 자원의 window 객체.
   * @param {String} sRequestHost 원격지 자원의 origin(프로토콜 + 도메인) 문자열 값. ex. 'https://m.search.naver.com'
   * @param {Object} htData 회신 데이터.
   * @private
   */
  _sendMessage : function(oRequestHost, sRequestHost, htData){
    if(!htData || !htData.reqId || !htData.resData){
      throw new Error("Not Exist Protocol Data.");
    }

    oRequestHost.postMessage(JSON.stringify(htData), sRequestHost);
  },

  //--------------------------------------------------------------------------
  //
  //	Event Handlers
  //
  //--------------------------------------------------------------------------

  //----------------------------------
  //	of window
  //----------------------------------

  /**
   * 상위 프레임에서 postMessage 로 호출할때 발생되는 이벤트 처리 핸들러
   * @method _onMessage
   * @param {MessageEvent} e 이벤트 객체.
   * @private
   */
  _onMessage : function(e){
    var htData,
        oResData;

    // 도메인 체크
    if(this._bCheckDomain && !this._isVerifyDomain(e.origin)){
      console.log("도메인이 유효하지 않음");
      return false;
    }

    htData = JSON.parse(e.data);
    this._sendMessage(e.source, e.origin, this._fCallback(htData));
  }
});

